Host *.plek.org
    ForwardAgent yes
    AddKeysToAgent yes

# Format is RemoteForward <remote_socket> <local_extra_stocket>
Host one.plek.org
    RemoteForward /run/user/1000/gnupg/S.gpg-agent /Users/tcole/.gnupg/S.gpg-agent.extra
    User kelp

Host two.plek.org
    RemoteForward /home/kelp/.gnupg/S.gpg-agent /run/user/1000/gnupg/S.gpg-agent.extra

Host *.plek.local
    ForwardAgent yes
    AddKeysToAgent yes
    RemoteForward /home/kelp/.gnupg/S.gpg-agent /Users/tcole/.gnupg/S.gpg-agent.extra
    User kelp

Host *
    ControlMaster auto
    ControlPersist 3600
